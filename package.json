{
  "name": "@workos/openapi-spec",
  "version": "0.40.0",
  "type": "module",
  "description": "WorkOS OpenAPI specification, TypeScript types, and SDK resolution policy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workos/openapi-spec.git"
  },
  "types": "./dist/types.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "default": "./dist/open-api-spec.yaml"
    },
    "./spec": "./dist/open-api-spec.yaml",
    "./policy": {
      "types": "./dist/policy.d.mts",
      "import": "./dist/policy.mjs"
    },
    "./services": {
      "types": "./dist/services.d.mts",
      "import": "./dist/services.mjs"
    },
    "./operation-overrides/node": "./dist/operationOverrides.node.json",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@workos/oagen": "^0.25.0"
  },
  "scripts": {
    "generate:services": "node scripts/generate-services.mjs",
    "build:policy": "npm run generate:services && tsdown",
    "test": "node --test scripts/__tests__/*.spec.mjs",
    "generate:postman": "tsx scripts/postman/generate.ts",
    "generate:postman:local": "tsx scripts/postman/generate.ts --local",
    "sdk:resolve": "npx oagen resolve --spec spec/open-api-spec.yaml",
    "sdk:generate": "bash scripts/sdk-generate.sh",
    "sdk:diff": "bash scripts/sdk-diff.sh",
    "sdk:verify": "bash scripts/sdk-verify.sh",
    "sdk:extract": "bash scripts/sdk-extract.sh",
    "sdk:compat-extract": "bash scripts/sdk-compat-extract.sh",
    "sdk:compat-diff": "bash scripts/sdk-compat-diff.sh",
    "sdk:compat-summary": "bash scripts/sdk-compat-summary.sh",
    "sdk:compat-report": "node scripts/sdk-compat-pr-comment.mjs --artifacts-root .oagen --output compat-report.md --build-result success",
    "sdk:languages": "node -e \"console.log(JSON.parse(require('fs').readFileSync('.github/sdk-matrix.json','utf8')).map(e=>e.language).join('\\n'))\"",
    "sdk:generate-all": "bash scripts/sdk-generate-all.sh --parent-dir",
    "sdk:check": "npx oagen resolve --spec spec/open-api-spec.yaml --format json > /dev/null && echo 'Config loaded successfully'",
    "dev:link": "npm link @workos/oagen @workos/oagen-emitters",
    "dev:unlink": "npm install",
    "prepare": "husky"
  },
  "overrides": {
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@workos/oagen-emitters": "^0.19.10",
    "diff2html": "^3.4.56",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "openapi-to-postmanv2": "^6.2.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
